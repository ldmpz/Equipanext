{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/contacto",
      "regex": "^/contacto(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contacto(?:/)?$"
    },
    {
      "page": "/disenador",
      "regex": "^/disenador(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/disenador(?:/)?$"
    },
    {
      "page": "/nosotros",
      "regex": "^/nosotros(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/nosotros(?:/)?$"
    },
    {
      "page": "/productos",
      "regex": "^/productos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/productos(?:/)?$"
    },
    {
      "page": "/servicios",
      "regex": "^/servicios(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/servicios(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}